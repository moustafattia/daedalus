#!/usr/bin/env bash
set -euo pipefail

PLUGIN="${DAEDALUS_PLUGIN:-${HOME}/.hermes/plugins/daedalus}"
ROOT="${DAEDALUS_WORKFLOW_ROOT:-}"
INTERVAL="${DAEDALUS_PROGRESS_INTERVAL:-10}"
WATCH=0
VERBOSE="${DAEDALUS_PROGRESS_VERBOSE:-0}"

usage() {
  cat <<'EOF'
Usage: daedalus-ticket-progress [watch] [--verbose] [--workflow-root PATH] [--plugin PATH] [--interval SECONDS]

Shows active change-delivery ticket progress with the working agent transcript
when Codex session JSONL files are available under ~/.codex/sessions.

Environment:
  DAEDALUS_PLUGIN                  Installed Daedalus plugin root
  DAEDALUS_WORKFLOW_ROOT           Workflow root
  DAEDALUS_PROGRESS_INTERVAL       Watch refresh interval
  DAEDALUS_PROGRESS_VERBOSE        1/true/on for verbose transcript output
  DAEDALUS_PROGRESS_AGENT_MESSAGES Number of agent messages to show
  DAEDALUS_PROGRESS_AGENT_TOOLS    Number of tool calls/outputs to show
  DAEDALUS_PROGRESS_AGENT_SESSIONS Number of Codex sessions to show
EOF
}

while (($#)); do
  case "$1" in
    watch|--watch)
      WATCH=1
      shift
      ;;
    verbose|--verbose|-v)
      VERBOSE=1
      shift
      ;;
    --workflow-root)
      ROOT="${2:?missing value for --workflow-root}"
      shift 2
      ;;
    --plugin)
      PLUGIN="${2:?missing value for --plugin}"
      shift 2
      ;;
    --interval)
      INTERVAL="${2:?missing value for --interval}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

resolve_workflow_root() {
  if [[ -n "$ROOT" ]]; then
    printf '%s\n' "$ROOT"
    return
  fi
  PYTHONPATH="$PLUGIN" python3 - "$PLUGIN" <<'PY'
import sys
from pathlib import Path

from workflows.shared.paths import resolve_default_workflow_root

print(resolve_default_workflow_root(plugin_dir=Path(sys.argv[1])))
PY
}

ROOT="$(resolve_workflow_root)"
export DAEDALUS_PROGRESS_VERBOSE="$VERBOSE"

render() {
  PYTHONPATH="$PLUGIN" python3 - "$PLUGIN" "$ROOT" <<'PY'
import json
import os
import re
import subprocess
import sys
from collections import deque
from datetime import datetime, timezone
from pathlib import Path

plugin, root = sys.argv[1], sys.argv[2]
env = os.environ.copy()
env["PYTHONPATH"] = plugin
verbose = str(os.environ.get("DAEDALUS_PROGRESS_VERBOSE", "")).lower() in {"1", "true", "yes", "on"}


def env_int(name, default):
    try:
        return int(os.environ.get(name, default))
    except Exception:
        return default


message_limit = env_int("DAEDALUS_PROGRESS_AGENT_MESSAGES", 8 if verbose else 3)
tool_limit = env_int("DAEDALUS_PROGRESS_AGENT_TOOLS", 14 if verbose else 5)
session_limit = env_int("DAEDALUS_PROGRESS_AGENT_SESSIONS", 3 if verbose else 2)
tail_limit = env_int("DAEDALUS_PROGRESS_AGENT_TAIL", 1400 if verbose else 700)
text_width = env_int("DAEDALUS_PROGRESS_TEXT_WIDTH", 180 if verbose else 132)


def run_json(argv):
    try:
        out = subprocess.check_output(
            argv,
            cwd="/tmp",
            env=env,
            stderr=subprocess.PIPE,
            text=True,
        )
        return json.loads(out)
    except subprocess.CalledProcessError as exc:
        msg = (exc.stderr or exc.output or str(exc)).strip()
        return {"_error": msg}
    except Exception as exc:
        return {"_error": str(exc)}


def pick(data, *keys, default="-"):
    cur = data
    for key in keys:
        if not isinstance(cur, dict) or key not in cur or cur[key] in (None, ""):
            return default
        cur = cur[key]
    return cur


def redact(value):
    value = str(value or "")
    replacements = [
        (r"gho_[A-Za-z0-9_]+", "gho_***"),
        (r"github_pat_[A-Za-z0-9_]+", "github_pat_***"),
        (r"Bearer\s+[A-Za-z0-9._~+/=-]+", "Bearer ***"),
        (r"(?i)(password|passwd|token|secret|api[_-]?key|authorization|cookie)=([^\\s&]+)", r"\1=***"),
        (r"(?i)(X-Amz-Signature|sig|signature)=([^\\s&]+)", r"\1=***"),
    ]
    for pattern, replacement in replacements:
        value = re.sub(pattern, replacement, value)
    return value


def compact(value, width=96):
    value = redact(str(value or "").replace("\n", " ").strip())
    if len(value) <= width:
        return value
    return value[: width - 1] + "..."


def stamp(value):
    value = str(value or "")
    if "T" in value:
        return value.split("T", 1)[1].replace("Z", "")[:8]
    return value[:8] if value else "-"


def run_text(argv, *, cwd="/tmp"):
    try:
        return subprocess.check_output(
            argv,
            cwd=cwd,
            env=env,
            stderr=subprocess.STDOUT,
            text=True,
        )
    except Exception as exc:
        return str(exc)


def parse_json_maybe(value):
    if isinstance(value, dict):
        return value
    if not isinstance(value, str):
        return {}
    try:
        loaded = json.loads(value)
        return loaded if isinstance(loaded, dict) else {}
    except Exception:
        return {}


def content_text(content):
    if isinstance(content, str):
        return content
    if not isinstance(content, list):
        return ""
    parts = []
    for item in content:
        if not isinstance(item, dict):
            continue
        if item.get("type") in {"output_text", "input_text", "text"}:
            text = item.get("text")
            if text:
                parts.append(str(text))
    return "\n".join(parts)


def describe_function_call(payload):
    name = payload.get("name") or "tool"
    namespace = payload.get("namespace")
    args = parse_json_maybe(payload.get("arguments"))
    if name == "exec_command":
        cmd = compact(args.get("cmd") or "", 118)
        workdir = args.get("workdir")
        return f"exec {cmd}" + (f" [{workdir}]" if workdir else "")
    if name == "write_stdin":
        return f"poll command session {args.get('session_id', '-')}"
    if name == "update_plan":
        items = args.get("plan") or []
        active = next((item for item in items if item.get("status") == "in_progress"), None)
        done = sum(1 for item in items if item.get("status") == "completed")
        if active:
            return f"plan {done}/{len(items)} done; active: {compact(active.get('step'), 76)}"
        return f"plan {done}/{len(items)} done"
    if namespace:
        return f"{namespace}.{name}"
    return str(name)


def describe_function_output(payload):
    output = str(payload.get("output") or "")
    if "Process running with session ID" in output:
        match = re.search(r"session ID (\d+)", output)
        return f"command still running session {match.group(1) if match else '-'}"
    code = None
    match = re.search(r"Process exited with code (-?\d+)", output)
    if match:
        code = match.group(1)
    lines = []
    in_output = False
    for raw in output.splitlines():
        line = raw.strip()
        if not line:
            continue
        if line == "Output:":
            in_output = True
            continue
        if line.startswith(("Chunk ID:", "Wall time:", "Original token count:")):
            continue
        if in_output or not line.startswith(("Process exited", "Process running")):
            lines.append(line)
    summary = " | ".join(lines[-3:]) if lines else "no output"
    prefix = f"exit {code}: " if code is not None else ""
    return prefix + compact(summary, 118)


def tail_jsonl(path, max_lines=700):
    rows = deque(maxlen=max_lines)
    try:
        with Path(path).open("r", encoding="utf-8", errors="replace") as handle:
            for line in handle:
                rows.append(line)
    except Exception:
        return []
    parsed = []
    for line in rows:
        try:
            parsed.append(json.loads(line))
        except Exception:
            continue
    return parsed


def session_meta(path):
    try:
        with Path(path).open("r", encoding="utf-8", errors="replace") as handle:
            first = handle.readline()
        item = json.loads(first)
        payload = item.get("payload") or {}
        return payload if item.get("type") == "session_meta" else {}
    except Exception:
        return {}


def codex_session_files_for_worktree(worktree, preferred_session_id=None, max_files=4):
    if not worktree:
        return []
    root_path = Path.home() / ".codex" / "sessions"
    if not root_path.exists():
        return []
    candidates = sorted(
        root_path.rglob("*.jsonl"),
        key=lambda item: item.stat().st_mtime if item.exists() else 0,
        reverse=True,
    )
    matches = []
    for path in candidates:
        meta = session_meta(path)
        if meta.get("cwd") != worktree:
            continue
        matches.append((path, meta))
        if len(matches) >= max_files:
            break
    if preferred_session_id:
        matches.sort(
            key=lambda item: (
                0 if item[1].get("id") == preferred_session_id else 1,
                -(item[0].stat().st_mtime if item[0].exists() else 0),
            )
        )
    return matches


def summarize_codex_session(path, meta, preferred_session_id=None):
    events = tail_jsonl(path, max_lines=tail_limit)
    messages = []
    tools = []
    token_summary = None
    last_message_text = None

    def remember_message(ts, kind, text):
        nonlocal last_message_text
        text = redact(str(text or "").strip())
        if not text or text in {".", "..."}:
            return
        if text == last_message_text:
            return
        last_message_text = text
        messages.append(f"{ts} {kind}: {compact(text, text_width)}")

    for item in events:
        ts = stamp(item.get("timestamp"))
        payload = item.get("payload") or {}
        if item.get("type") == "event_msg":
            event_type = payload.get("type")
            if event_type == "agent_message":
                remember_message(ts, "assistant", payload.get("message"))
            elif event_type == "task_complete":
                remember_message(ts, "complete", payload.get("last_agent_message"))
            elif event_type == "token_count":
                info = payload.get("info") or {}
                total = info.get("total_token_usage") or {}
                last = info.get("last_token_usage") or {}
                rate = payload.get("rate_limits") or {}
                primary = rate.get("primary") or {}
                token_summary = (
                    f"last={last.get('total_tokens', '-')} total={total.get('total_tokens', '-')} "
                    f"primary={primary.get('used_percent', '-')}%"
                )
        elif item.get("type") == "response_item":
            response_type = payload.get("type")
            if response_type == "function_call":
                tools.append(f"{ts} call: {describe_function_call(payload)}")
            elif response_type == "function_call_output":
                tools.append(f"{ts} out:  {describe_function_output(payload)}")
            elif response_type == "message" and payload.get("role") == "assistant":
                remember_message(ts, "assistant", content_text(payload.get("content")))
    session_id = meta.get("id") or path.stem
    role = "coder" if preferred_session_id and session_id == preferred_session_id else "agent"
    try:
        mtime = datetime.fromtimestamp(path.stat().st_mtime, timezone.utc).strftime("%H:%M:%S")
    except Exception:
        mtime = "-"
    return {
        "role": role,
        "id": session_id,
        "mtime": mtime,
        "model": meta.get("model") or meta.get("model_provider") or "-",
        "source": meta.get("originator") or meta.get("source") or "-",
        "messages": messages[-message_limit:],
        "tools": tools[-tool_limit:],
        "token_summary": token_summary,
    }


def git_worktree_summary(worktree):
    if not worktree or not Path(worktree).exists():
        return []
    status_text = run_text(["git", "-C", worktree, "status", "--short"]).strip()
    head = run_text(["git", "-C", worktree, "log", "-1", "--oneline"]).strip()
    diff_stat = run_text(["git", "-C", worktree, "diff", "--stat", "origin/main...HEAD"]).strip()
    status_lines = [line for line in status_text.splitlines() if line.strip()]
    result = [f"head: {compact(head, 120)}"]
    result.append(f"dirty files: {len(status_lines)}" if status_lines else "dirty files: 0")
    if diff_stat:
        result.extend(compact(line, 132) for line in diff_stat.splitlines()[-4:])
    return result


status = run_json(
    [
        sys.executable,
        f"{plugin}/workflows/__main__.py",
        "--workflow-root",
        root,
        "status",
        "--json",
    ]
)
events = run_json(
    [
        sys.executable,
        f"{plugin}/daedalus_cli.py",
        "events",
        "--workflow-root",
        root,
        "--limit",
        "14",
        "--format",
        "json",
    ]
)
runs = run_json(
    [
        sys.executable,
        f"{plugin}/daedalus_cli.py",
        "runs",
        "--workflow-root",
        root,
        "--limit",
        "6",
        "--format",
        "json",
    ]
)

now = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M:%SZ")
print(f"Daedalus ticket progress - {now}")
print(f"Workflow root: {root}")

if "_error" in status:
    print()
    print("Status: ERROR")
    print(compact(status["_error"], 160))
    sys.exit(1)

active = status.get("activeLane") or {}
ledger = status.get("ledger") or {}
implementation = status.get("implementation") or {}
reviews = status.get("reviews") or {}
next_action = status.get("nextAction") or {}
doctor = status.get("doctor") or status.get("health") or {}

number = active.get("number") or active.get("issueNumber") or "-"
title = active.get("title") or "-"
url = active.get("url") or active.get("htmlUrl") or "-"
lane_id = active.get("laneId") or (f"lane:{number}" if number != "-" else "-")

print()
if number == "-":
    print("Active ticket: none")
else:
    print(f"Active ticket: #{number} {compact(title, 110)}")
    print(f"URL: {url}")
    print(f"Lane: {lane_id}")

workflow_state = pick(ledger, "workflowState")
review_state = pick(ledger, "reviewState")
ledger_active = pick(ledger, "activeLane", "number", default=None)
if ledger_active is None:
    ledger_active = pick(ledger, "activeLane", default="-")

health_text = "-"
if isinstance(doctor, dict):
    health_text = doctor.get("overall") or doctor.get("status") or "-"
else:
    health_text = str(doctor or "-")

print()
print(f"Health: {health_text}")
print(f"Workflow: {workflow_state} | Review: {review_state}")
print(
    "Next action: "
    f"{pick(next_action, 'type')} "
    f"{compact(pick(next_action, 'reason', default=''), 80)}"
)

if number != "-" and ledger_active not in ("-", number, str(number), f"lane:{number}"):
    print()
    print(
        "ATTENTION: GitHub active lane and Daedalus ledger differ. "
        "If runs stay noop, reconcile the workflow."
    )
    print(f"GitHub lane: #{number} | Ledger active lane: {ledger_active}")

print()
print("Coder:")
print(f"  session: {pick(implementation, 'resumeSessionId')}")
print(f"  branch:  {pick(implementation, 'branch')}")
print(f"  worktree:{pick(implementation, 'worktree')}")
print(f"  publish: {pick(implementation, 'publishStatus')}")
print(f"  head:    {pick(implementation, 'localHeadSha')}")

runtime_metrics = implementation.get("runtimeMetrics") or {}
tokens = runtime_metrics.get("tokens") or {}
rate_limits = runtime_metrics.get("rate_limits") or {}
primary_limit = rate_limits.get("primary") or {}
lane_state = implementation.get("laneState") or {}
lane_impl = lane_state.get("implementation") or {}
worktree = implementation.get("worktree")
session_id = implementation.get("resumeSessionId")

print()
print("Agent activity:")
print(
    "  runtime: "
    f"event={pick(implementation, 'lastRuntimeEvent')} "
    f"turn={pick(implementation, 'turnId')} "
    f"tokens={tokens.get('total_tokens', '-')} "
    f"rate={primary_limit.get('usedPercent', primary_limit.get('used_percent', '-'))}%"
)
last_runtime_message = str(implementation.get("lastRuntimeMessage") or "").strip()
if last_runtime_message and last_runtime_message not in {".", "..."}:
    print(f"  last message: {compact(last_runtime_message, text_width)}")
print(
    "  progress: "
    f"{pick(lane_impl, 'lastMeaningfulProgressKind')} "
    f"at {pick(lane_impl, 'lastMeaningfulProgressAt')}"
)
for line in git_worktree_summary(worktree):
    print(f"  git: {line}")

sessions = [
    summarize_codex_session(path, meta, preferred_session_id=session_id)
    for path, meta in codex_session_files_for_worktree(worktree, preferred_session_id=session_id)
]
if not sessions:
    print("  transcript: no Codex session JSONL found for this worktree yet")
else:
    for session in sessions[:session_limit]:
        print(
            f"  transcript: {session['role']} {session['id']} "
            f"updated={session['mtime']} source={session['source']} model={session['model']}"
        )
        if session.get("token_summary"):
            print(f"    tokens: {session['token_summary']}")
        for message in session["messages"]:
            print(f"    {message}")
        if session["tools"]:
            print("    recent tools:")
            for tool_line in session["tools"][-tool_limit:]:
                print(f"      {tool_line}")

internal = reviews.get("internal") or reviews.get("internalReview") or {}
external = reviews.get("external") or reviews.get("externalReview") or {}
pr = status.get("pullRequest") or status.get("pr") or status.get("openPr") or {}

print()
print("Review / PR:")
print(
    "  internal: "
    f"{pick(internal, 'state')} "
    f"{compact(pick(internal, 'verdict', default=''), 64)}"
)
print(
    "  external: "
    f"{pick(external, 'state')} "
    f"{compact(pick(external, 'verdict', default=''), 64)}"
)
print(f"  PR:       {pick(pr, 'number')} {pick(pr, 'url')}")

print()
print("Recent runs:")
run_items = runs.get("runs") if isinstance(runs, dict) else None
if not run_items and isinstance(runs, list):
    run_items = runs
if not run_items:
    err = runs.get("_error") if isinstance(runs, dict) else None
    print(f"  {compact(err or 'none')}")
else:
    for run in run_items[:6]:
        meta = run.get("metadata") or {}
        print(
            "  "
            f"{stamp(run.get('startedAt') or run.get('createdAt'))} "
            f"{compact(run.get('runType') or run.get('kind') or '-', 24)} "
            f"{compact(run.get('status') or '-', 12)} "
            f"{compact(meta.get('iteration_status') or meta.get('status') or '', 20)} "
            f"{compact(meta.get('reason') or '', 44)} "
            f"{compact(meta.get('lane_id') or '', 16)}"
        )

print()
print("Recent ticket events:")
event_items = events.get("events") if isinstance(events, dict) else None
if not event_items and isinstance(events, list):
    event_items = events
shown = 0
if event_items:
    for event in event_items:
        event_type = event.get("eventType") or event.get("event_type") or "-"
        if event_type == "daedalus.runtime_heartbeat":
            continue
        payload = event.get("payload") or {}
        nested = payload.get("payload") if isinstance(payload.get("payload"), dict) else {}
        issue = (
            payload.get("issue_number")
            or payload.get("issueNumber")
            or nested.get("issue_number")
            or nested.get("issueNumber")
            or ""
        )
        summary = (
            payload.get("summary")
            or nested.get("summary")
            or payload.get("reason")
            or nested.get("reason")
            or payload.get("action_type")
            or nested.get("action_type")
            or ""
        )
        issue_text = f"#{issue} " if issue else ""
        print(
            "  "
            f"{stamp(event.get('createdAt') or event.get('created_at'))} "
            f"{compact(event_type, 38)} "
            f"{issue_text}{compact(summary, 70)}"
        )
        shown += 1
        if shown >= 8:
            break
if shown == 0:
    err = events.get("_error") if isinstance(events, dict) else None
    print(f"  {compact(err or 'none')}")
PY
}

if [[ "$WATCH" == "1" ]]; then
  while true; do
    clear
    render
    sleep "$INTERVAL"
  done
else
  render
fi
